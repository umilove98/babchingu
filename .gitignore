# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# editor/agent local metadata
.claude/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma local dev db
/prisma/dev.db
/prisma/dev.db-journal
/prisma/migrations/dev.db*

# dev server logs and curl cookie jars (E2E test artifacts)
*.log
*cookies*.txt
/alice.txt
/bob.txt
/carol.txt

# user-uploaded files (avatars, etc.)
/public/uploads
