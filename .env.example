# Supabase Postgres — ORM 탭에서 "Prisma" 선택 시 보여주는 두 URL
# DATABASE_URL: 앱 런타임 (Transaction pooler, port 6543)
# DIRECT_URL: Prisma migrate 전용 (Direct connection, port 5432)
DATABASE_URL="postgresql://postgres.xxxxx:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.xxxxx:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres"

# Supabase Storage (아바타 업로드)
# Connect 다이얼로그 → Framework 탭에서 NEXT_PUBLIC_SUPABASE_URL 값
NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
# Settings → API → Secret keys → default 의 sb_secret_... 전체값
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# iron-session 암호화 키. 반드시 32자 이상 랜덤.
# 생성 예: -join ((48..57)+(65..90)+(97..122)|Get-Random -Count 48|%{[char]$_})
SESSION_SECRET="please-replace-with-32-chars-or-more-random-string-in-production"

# Web Push (VAPID) — `npx web-push generate-vapid-keys` 로 한 번 발급.
# - public/private 키는 발급 결과 그대로 복사
# - NEXT_PUBLIC_VAPID_PUBLIC_KEY 는 VAPID_PUBLIC_KEY 와 같은 값 (클라이언트 노출용)
# - VAPID_SUBJECT 는 운영자 mailto 또는 https URL
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_SUBJECT="mailto:admin@babchingu.local"
