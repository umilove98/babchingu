// 밥친구 — Supabase Postgres
// DATABASE_URL: Transaction pooler (port 6543, ?pgbouncer=true)
// DIRECT_URL: Direct connection (port 5432) — Prisma migrate 용

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id           String   @id @default(cuid())
  username     String   @unique
  displayName  String
  passwordHash String
  avatarSeed   String   // DiceBear 시드 (avatarUrl 없을 때 폴백)
  avatarUrl    String?  // 업로드한 아바타 이미지 경로
  canHost      Boolean  @default(false)
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())

  // 알림 수신 환경설정 — 끄면 in-app + push 둘 다 수신 안 함.
  // invited / change_requested / change_approved / change_rejected /
  // restaurant_changed 는 고정 ON 으로 컬럼 없음.
  notifParticipants Boolean @default(true)  // new_member, left
  notifComments     Boolean @default(true)  // new_comment
  notifNewParties   Boolean @default(true)  // party_created

  // 프로필 메뉴 태그 — 콤마로 구분된 짧은 키워드 (해시태그 형식). 공개.
  favoriteMenus String @default("")
  dislikedMenus String @default("")

  hostedParties        Party[]                   @relation("PartyHost")
  participations       Participation[]
  comments             Comment[]
  changeRequests       RestaurantChangeRequest[]
  notificationsRecv    Notification[]            @relation("NotifReceiver")
  notificationsActed   Notification[]            @relation("NotifActor")
  pushSubscriptions    PushSubscription[]
  coffeeBellsInitiated CoffeeBell[]              @relation("CoffeeBellInitiator")
  coffeeBellTargets    CoffeeBellTarget[]
  coffeeBellMessages   CoffeeBellMessage[]
}

model Party {
  id             String   @id @default(cuid())
  partyDate      String   // 'YYYY-MM-DD' (KST). SQLite Date 회피용 문자열.
  kind           String   // 'dosirak' | 'eatout'
  restaurantName String?
  mapUrl         String?
  hostId         String?
  createdAt      DateTime @default(now())

  host           Profile? @relation("PartyHost", fields: [hostId], references: [id], onDelete: SetNull)
  participations Participation[]
  guests         GuestParticipation[]
  comments       Comment[]
  changeRequests RestaurantChangeRequest[]
  notifications  Notification[]

  // 도시락은 결정적 ID(`dos_YYYY-MM-DD`)로 중복 방지 (PK가 dedup 역할).
  // 외식은 같은 날 같은 호스트가 여러 식당 등록 가능 (제약 없음).
  @@index([partyDate])
  @@index([hostId, partyDate])
}

model Participation {
  partyId  String
  userId   String
  joinedAt DateTime @default(now())

  party Party   @relation(fields: [partyId], references: [id], onDelete: Cascade)
  user  Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([partyId, userId])
  @@index([userId])
}

// 비회원(손님) 참가 — 초대 링크로 접근한 사람용.
// token 은 클라이언트가 생성한 ID로, 같은 브라우저에서만 자기 참가 취소 가능.
model GuestParticipation {
  id       String   @id @default(cuid())
  partyId  String
  name     String   // 손님이 입력한 이름
  token    String   // 클라이언트 localStorage 의 익명 식별자
  joinedAt DateTime @default(now())

  party Party @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@unique([partyId, token])
  @@index([partyId])
}

model Comment {
  id        String   @id @default(cuid())
  partyId   String
  userId    String
  body      String
  createdAt DateTime @default(now())

  party Party   @relation(fields: [partyId], references: [id], onDelete: Cascade)
  user  Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([partyId, createdAt])
}

model RestaurantChangeRequest {
  id          String    @id @default(cuid())
  partyId     String
  requesterId String
  newName     String
  newMapUrl   String?
  reason      String?
  status      String    @default("pending") // 'pending' | 'approved' | 'rejected'
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  party     Party   @relation(fields: [partyId], references: [id], onDelete: Cascade)
  requester Profile @relation(fields: [requesterId], references: [id], onDelete: Cascade)

  @@index([partyId, status])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String    // 받는 사람
  kind      String    // 'new_member' | 'new_comment' | 'change_requested' | 'restaurant_changed'
  partyId   String?
  actorId   String?
  payload   String?   // JSON 문자열 (before/after 식당명 등)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user  Profile  @relation("NotifReceiver", fields: [userId], references: [id], onDelete: Cascade)
  actor Profile? @relation("NotifActor", fields: [actorId], references: [id], onDelete: SetNull)
  party Party?   @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model CustomHoliday {
  date      String   @id   // 'YYYY-MM-DD'
  reason    String
  createdBy String?
  createdAt DateTime @default(now())
}

// 기습 모임 (커피/흡연) — 전 조직 동시 kind별 1개. endedAt IS NULL 이면 활성.
// 테이블명은 호환성 유지 위해 CoffeeBell 그대로 사용.
model CoffeeBell {
  id          String    @id @default(cuid())
  initiatorId String
  kind        String    @default("coffee") // 'coffee' | 'smoke'
  timing      String    // 'now' | '5min' | '10min' | '30min' | '1hour'
  createdAt   DateTime  @default(now())
  endedAt     DateTime?

  initiator Profile             @relation("CoffeeBellInitiator", fields: [initiatorId], references: [id], onDelete: Cascade)
  targets   CoffeeBellTarget[]
  messages  CoffeeBellMessage[]

  @@index([kind, endedAt, createdAt])
}

model CoffeeBellTarget {
  coffeeBellId String
  userId       String
  available    Boolean   @default(false)
  respondedAt  DateTime?

  coffeeBell CoffeeBell @relation(fields: [coffeeBellId], references: [id], onDelete: Cascade)
  user       Profile    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([coffeeBellId, userId])
  @@index([userId])
}

model CoffeeBellMessage {
  id           String   @id @default(cuid())
  coffeeBellId String
  userId       String
  body         String
  createdAt    DateTime @default(now())

  coffeeBell CoffeeBell @relation(fields: [coffeeBellId], references: [id], onDelete: Cascade)
  user       Profile    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([coffeeBellId, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String   // Web Push Encryption public key
  auth      String   // Web Push auth secret
  userAgent String?  // 디버깅용 (어떤 브라우저/기기)
  createdAt DateTime @default(now())

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
